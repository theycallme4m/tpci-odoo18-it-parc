<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence équipements -->
        <record id="sequence_it_equipement" model="ir.sequence">
            <field name="name">Équipement IT</field>
            <field name="code">it.equipement</field>
            <field name="prefix">EQ-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Paramètre système : délai d'alerte par défaut -->
        <record id="param_delai_alerte" model="ir.config_parameter">
            <field name="key">it_parc.delai_alerte</field>
            <field name="value">30</field>
        </record>

        <!-- Tâche planifiée : génération des alertes (quotidien) -->
        <record id="cron_generer_alertes" model="ir.cron">
            <field name="name">IT Parc : Génération des alertes garanties/contrats</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="state">code</field>
            <field name="code">model._cron_generer_alertes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
