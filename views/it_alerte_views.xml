<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_alerte_list" model="ir.ui.view">
        <field name="name">it.alerte.list</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <list string="Alertes"
                  decoration-danger="jours_restants &lt;= 7 and state == 'active'"
                  decoration-warning="jours_restants &lt;= 30 and state == 'active'"
                  decoration-muted="state == 'traitee'">
                <field name="name"/>
                <field name="type_alerte" widget="badge"/>
                <field name="equipement_id"/>
                <field name="contrat_id"/>
                <field name="date_expiration"/>
                <field name="jours_restants"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'active'"
                       decoration-success="state == 'traitee'"/>
                <button name="action_traiter" string="Traiter" type="object"
                        icon="fa-check" invisible="state != 'active'"
                        groups="it_parc.group_it_manager"/>
            </list>
        </field>
    </record>

    <record id="view_it_alerte_form" model="ir.ui.view">
        <field name="name">it.alerte.form</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <form string="Alerte">
                <header>
                    <button name="action_traiter" string="Marquer traitée" type="object"
                            invisible="state != 'active'" class="btn-primary"
                            groups="it_parc.group_it_manager"/>
                    <button name="action_reactivate" string="Réactiver" type="object"
                            invisible="state != 'traitee'"
                            groups="it_parc.group_it_manager"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Alerte"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="type_alerte"/>
                            <field name="equipement_id" invisible="type_alerte != 'garantie'"/>
                            <field name="contrat_id" invisible="type_alerte != 'contrat'"/>
                        </group>
                        <group>
                            <field name="date_expiration"/>
                            <field name="jours_restants"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_it_alerte_search" model="ir.ui.view">
        <field name="name">it.alerte.search</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="active" string="Actives" domain="[('state','=','active')]"/>
                <filter name="traitee" string="Traitées" domain="[('state','=','traitee')]"/>
                <filter name="garantie" string="Garanties" domain="[('type_alerte','=','garantie')]"/>
                <filter name="contrat" string="Contrats" domain="[('type_alerte','=','contrat')]"/>
                <filter name="urgente" string="Urgentes (&lt;= 7j)" domain="[('jours_restants','&lt;=',7),('state','=','active')]"/>
            </search>
        </field>
    </record>

    <record id="action_it_alerte" model="ir.actions.act_window">
        <field name="name">Alertes</field>
        <field name="res_model">it.alerte</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_it_alerte_search"/>
        <field name="domain">[('state','=','active')]</field>
    </record>

</odoo>
