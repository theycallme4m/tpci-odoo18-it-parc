<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_affectation_list" model="ir.ui.view">
        <field name="name">it.affectation.list</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <list string="Historique des affectations" default_order="date_debut desc">
                <field name="equipement_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="motif"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_it_affectation_form" model="ir.ui.view">
        <field name="name">it.affectation.form</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <form string="Affectation">
                <sheet>
                    <group>
                        <group>
                            <field name="equipement_id"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="date_debut"/>
                            <field name="date_fin"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Motif">
                        <field name="motif" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_affectation" model="ir.actions.act_window">
        <field name="name">Historique affectations</field>
        <field name="res_model">it.affectation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
