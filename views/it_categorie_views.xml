<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_categorie_list" model="ir.ui.view">
        <field name="name">it.categorie.list</field>
        <field name="model">it.categorie</field>
        <field name="arch" type="xml">
            <list string="Catégories d'équipements">
                <field name="name"/>
                <field name="nb_equipements"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_it_categorie_form" model="ir.ui.view">
        <field name="name">it.categorie.form</field>
        <field name="model">it.categorie</field>
        <field name="arch" type="xml">
            <form string="Catégorie d'équipement">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la catégorie"/>
                        </h1>
                    </div>
                    <group>
                        <field name="nb_equipements"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_categorie" model="ir.actions.act_window">
        <field name="name">Catégories</field>
        <field name="res_model">it.categorie</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
